# LenaBeauty — Environment template.
# Copy to `.env` for local dev. NEVER commit real values.
# In production, set these in the Vercel dashboard
# (Project -> Settings -> Environment Variables), NOT in vercel.json.

VITE_DATA_BACKEND=supabase

# From Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# The center UUID seeded by the initial schema migration.
VITE_CENTER_ID=00000000-0000-0000-0000-000000000000

VITE_BRANCH_MODE=single
